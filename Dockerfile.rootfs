# Stage 1: Full development toolchain for the builder template.
# Installs Go (matching go.mod) plus linters, compilers, and language runtimes.
FROM alpine:3.21 AS go-builder
ARG TARGETARCH
RUN apk add --no-cache bash curl wget ca-certificates git make gcc musl-dev linux-headers openssl python3 nodejs
RUN curl -fsSL "https://go.dev/dl/go1.25.0.linux-${TARGETARCH}.tar.gz" | tar -xz -C /usr/local
ENV PATH=$PATH:/usr/local/go/bin
RUN go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && \
    go install honnef.co/go/tools/cmd/staticcheck@latest && \
    go install github.com/securego/gosec/v2/cmd/gosec@latest && \
    mkdir -p /etc/profile.d /etc/init.d && \
    printf 'export PATH=/usr/local/go/bin:/usr/local/bin:$PATH\nexport GOPATH=/workspace/go\nexport GOCACHE=/workspace/.cache/go-build\nexport GOMODCACHE=/workspace/go/pkg/mod\n' > /etc/profile.d/go.sh && \
    printf '#!/bin/sh\ncase "$1" in\n    start) echo "Builder agent starting..." ;;\n    stop)  echo "Builder agent stopping..." ;;\nesac\n' > /etc/init.d/builder-agent && \
    chmod +x /etc/init.d/builder-agent

# Stage 2: Minimal runtime base for guest and portal VMs.
# Includes language runtimes (bash, python3, nodejs) but no compilers or dev tools.
FROM alpine:3.21 AS runtime-base
RUN apk add --no-cache bash ca-certificates python3 nodejs

# Stage 3: Ultra-minimal base for AegisHub (IPC router — no language runtimes needed).
FROM alpine:3.21 AS minimal-base
RUN apk add --no-cache ca-certificates

# Stage 4: Assemble per-target template layouts.
FROM alpine:3.21 AS final
RUN mkdir -p /templates/guest /templates/aegishub /templates/portal /templates/builder

# Guest template: alpine runtime only (bash, python3, nodejs, certs — no dev tools).
COPY --from=runtime-base /bin    /templates/guest/bin
COPY --from=runtime-base /sbin   /templates/guest/sbin
COPY --from=runtime-base /usr    /templates/guest/usr
COPY --from=runtime-base /etc    /templates/guest/etc
COPY --from=runtime-base /lib    /templates/guest/lib

# AegisHub template: busybox + certs only (router binary injected by build script).
COPY --from=minimal-base /bin    /templates/aegishub/bin
COPY --from=minimal-base /sbin   /templates/aegishub/sbin
COPY --from=minimal-base /lib    /templates/aegishub/lib
COPY --from=minimal-base /etc    /templates/aegishub/etc
COPY --from=minimal-base /usr    /templates/aegishub/usr

# Portal template: busybox + certs only (portal binary injected by build script).
COPY --from=minimal-base /bin    /templates/portal/bin
COPY --from=minimal-base /sbin   /templates/portal/sbin
COPY --from=minimal-base /lib    /templates/portal/lib
COPY --from=minimal-base /etc    /templates/portal/etc
COPY --from=minimal-base /usr    /templates/portal/usr

# Builder template: full dev toolchain + Go (for in-VM builds and analysis).
COPY --from=go-builder /bin      /templates/builder/bin
COPY --from=go-builder /sbin     /templates/builder/sbin
COPY --from=go-builder /usr      /templates/builder/usr
COPY --from=go-builder /etc      /templates/builder/etc
COPY --from=go-builder /lib      /templates/builder/lib

# ─── Docker-mode runnable images ──────────────────────────────────────────────
#
# The stages below produce self-contained OCI images that can be run directly
# with `docker run` when isolation_mode = "docker".  The guest-agent binary is
# NOT included here because it is injected at build time by the build script.
# The CMD/ENTRYPOINT stubs below are replaced at build time by the script.

# aegisclaw/guest:latest — minimal runtime container for skill/agent VMs.
FROM runtime-base AS aegisclaw-guest
ARG TARGETARCH
RUN mkdir -p /run/aegis /workspace /tmp/secrets
# Placeholder CMD replaced by build script when guest-agent is injected.
CMD ["/sbin/guest-agent", "--transport=unix"]

# aegisclaw/aegishub:latest — ultra-minimal IPC router container.
FROM minimal-base AS aegisclaw-aegishub
RUN mkdir -p /run/aegis
CMD ["/sbin/aegishub"]

# aegisclaw/portal:latest — dashboard portal container.
FROM minimal-base AS aegisclaw-portal
RUN mkdir -p /run/aegis
CMD ["/sbin/aegisportal"]

# aegisclaw/builder:latest — full dev toolchain container for in-daemon skill builds.
FROM go-builder AS aegisclaw-builder
RUN mkdir -p /workspace /run/aegis
WORKDIR /workspace
CMD ["/sbin/builder-agent"]

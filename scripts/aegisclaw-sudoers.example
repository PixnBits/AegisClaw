# Example sudoers fragment for passwordless agent debugging on a dev machine.
# sudoers.d does NOT allow wildcards — list exact command paths only.
#
# Install (edit YOURUSER and paths first):
#   sudo cp scripts/aegisclaw-sudoers.example /etc/sudoers.d/aegisclaw
#   sudo chmod 440 /etc/sudoers.d/aegisclaw
#   sudo visudo -c
#
# For reading Firecracker console logs, use sudo directly (no wildcard rules), e.g.:
#   sudo tail -100 /root/.aegis/state/fc-web-portal-console.log

YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/bin/aegis
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/build-microvms-docker.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/clean-firecracker-rootfs.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/create-firecracker-rootfs.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/ensure-aegis-dir.sh

# Example for this specific workspace (edit paths as needed):
# /home/pixnbits/projects/AegisClaw/main/bin/aegis is the key one for `sudo -n ./bin/aegis start` and `make start*` (which invoke it under sudo -n internally).
# Use direct bin for start to avoid broad sudo on make: sudo -n /home/pixnbits/projects/AegisClaw/main/bin/aegis start --foreground

Defaults! /path/to/AegisClaw/main/bin/aegis env_keep += "AEGIS_BOOT_TIMING"
Defaults! /path/to/AegisClaw/main/bin/aegis env_keep += "AEGIS_DEFAULT_MODEL"
Defaults! /path/to/AegisClaw/main/bin/aegis env_keep += "AEGIS_HUB_SOCKET"
Defaults! /path/to/AegisClaw/main/bin/aegis env_keep += "AEGIS_STATE_DIR"


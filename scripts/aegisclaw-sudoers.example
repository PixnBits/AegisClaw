# Example sudoers fragment for passwordless agent debugging on a dev machine.
# sudoers.d does NOT allow wildcards — list exact command paths only.
#
# Install (edit YOURUSER and paths first):
#   sudo cp scripts/aegisclaw-sudoers.example /etc/sudoers.d/aegisclaw
#   sudo chmod 440 /etc/sudoers.d/aegisclaw
#   sudo visudo -c
#
# For reading Firecracker console logs, use sudo directly (no wildcard rules), e.g.:
#   sudo tail -100 /root/.aegis/state/fc-web-portal-console.log

YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/bin/aegis
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/build-microvms-docker.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/clean-firecracker-rootfs.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/create-firecracker-rootfs.sh
YOURUSER ALL=(ALL) NOPASSWD: /path/to/AegisClaw/scripts/ensure-aegis-dir.sh

# For E2E/test cleanup reliability (priority 1: repeated `make test-e2e-llm` after partials/interrupts on real Firecracker/sudo hw).
# Allows sudo -n pkill/rm in scripts/verify-pm-llm-e2e.sh and `make e2e-clean` without password prompts.
# Only for dev machines; review before installing.
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -x aegis
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -x aegishub
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -f aegis
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -f 'aegis start --foreground'
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -f 'aegishub start'
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/pkill -f 'aegis-daemon'
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/rm
YOURUSER ALL=(ALL) NOPASSWD: /bin/rm
# Explicit for main daemon artifacts left by sudo starts (hub socket in user's homedir, pid in /tmp).
# Add your full path for YOURUSER.
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/rm /home/pixnbits/.aegis/hub.sock
YOURUSER ALL=(ALL) NOPASSWD: /bin/rm /home/pixnbits/.aegis/hub.sock
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/rm /tmp/aegis/daemon.pid
YOURUSER ALL=(ALL) NOPASSWD: /bin/rm /tmp/aegis/daemon.pid
YOURUSER ALL=(ALL) NOPASSWD: /usr/bin/rm /tmp/aegis
YOURUSER ALL=(ALL) NOPASSWD: /bin/rm /tmp/aegis

# Example for this workspace (edit YOURUSER and paths):
YOURUSER ALL=(ALL) NOPASSWD: /home/pixnbits/projects/AegisClaw/main/bin/aegis
Defaults! /home/pixnbits/projects/AegisClaw/main/bin/aegis env_keep += "AEGIS_BOOT_TIMING AEGIS_COLLAB_TRACE AEGIS_DEFAULT_MODEL AEGIS_HUB_SOCKET AEGIS_STATE_DIR"

# Env vars for observability (boot-metrics, collab trace, model selection) when using sudo -E.
# Prefer `aegis start --collab-trace` instead of inline AEGIS_COLLAB_TRACE=1 (often blocked by sudo).
Defaults env_keep += "AEGIS_BOOT_TIMING AEGIS_COLLAB_TRACE AEGIS_DEFAULT_MODEL AEGIS_HUB_SOCKET AEGIS_STATE_DIR"


{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Proposal Create Draft Payload",
  "type": "object",
  "required": ["title", "description", "skill_name", "tools"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["new_skill", "edit_skill", "delete_skill", "kernel_patch", "config_change"]
    },
    "author": {
      "type": "string"
    },
    "spec": {
      "type": ["object", "null"],
      "description": "Opaque JSON spec for the skill (optional)"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "args_schema": { "type": ["object", "null"], "description": "Optional schema for tool args" }
        }
      }
    },
    "secrets_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_\\-]{0,127}$"
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": { "type": "boolean" },
        "filesystem_write": { "type": "boolean" },
        "host_devices": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "secrets": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_\\-]{0,127}$" },
          "uniqueItems": true
        },
        "can_access_other_sessions": { "type": "boolean" }
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_deny"],
      "properties": {
        "default_deny": { "type": "boolean", "const": true },
        "allowed_hosts": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "allowed_ports": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 65535
          },
          "uniqueItems": true
        },
        "allowed_protocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tcp", "udp", "icmp"]
          },
          "uniqueItems": true
        },
        "egress_mode": {
          "type": "string",
          "enum": ["proxy", "direct", ""]
        }
      }
    },
    "allowed_hosts": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Legacy top-level allowed_hosts (handlers will merge into network_policy.allowed_hosts)"
    },
    "allowed_ports": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 65535 },
      "uniqueItems": true,
      "description": "Legacy top-level allowed_ports (handlers will merge into network_policy.allowed_ports)"
    },
    "data_sensitivity": { "type": "integer", "minimum": 0, "maximum": 5 },
    "network_exposure": { "type": "integer", "minimum": 0, "maximum": 5 },
    "privilege_level": { "type": "integer", "minimum": 0, "maximum": 5 }
  }
}
